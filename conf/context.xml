<?xml version="1.0" encoding="UTF-8"?>
<Context>

    <WatchedResource>WEB-INF/web.xml</WatchedResource>
    <WatchedResource>${catalina.base}/conf/web.xml</WatchedResource>

    <!--
      JNDI DataSource for CheckoutWeb.
      Applications look this up as java:comp/env/jdbc/CheckoutDS.

      Key change:
        - maxWaitMillis is bounded so threads fail fast when the connection pool is exhausted.

      DBA agreement / connection ceiling:
        - keep maxTotal at 8 (maximum concurrent DB connections from this app).
    -->
    <Resource name="jdbc/CheckoutDS"
              auth="Container"
              type="javax.sql.DataSource"
              driverClassName="org.postgresql.Driver"
              url="jdbc:postgresql://checkoutweb-postgres:5432/checkout_db"
              username="checkout_app"
              password="checkout_pass"
              maxTotal="8"
              maxIdle="4"
              minIdle="0"
              maxWaitMillis="1000"

              validationQuery="SELECT 1"
              testOnBorrow="true"

              removeAbandonedOnBorrow="true"
              removeAbandonedTimeout="30"
              logAbandoned="true" />

</Context>
