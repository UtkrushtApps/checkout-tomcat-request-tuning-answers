<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>CheckoutWeb</display-name>

    <listener>
        <listener-class>com.example.tomcat.listener.AppLifecycleListener</listener-class>
    </listener>

    <filter>
        <filter-name>RequestCorrelationFilter</filter-name>
        <filter-class>com.example.tomcat.filter.RequestCorrelationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RequestCorrelationFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>AppServlet</servlet-name>
        <servlet-class>com.example.tomcat.AppServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AppServlet</servlet-name>
        <url-pattern>/health</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AppServlet</servlet-name>
        <url-pattern>/orders</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CheckoutServlet</servlet-name>
        <servlet-class>com.example.tomcat.CheckoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckoutServlet</servlet-name>
        <url-pattern>/checkout/place</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
